---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FAQSection from '../../components/FAQSection.astro';
import { getCollection } from 'astro:content';

export const prerender = true;

const siteUrl = import.meta.env.SITE || 'https://realestateai.tools';

export async function getStaticPaths() {
  const listings = await getCollection('listings');
  const all = listings.map((l) => l.data);

  const pairSlug = (a: any, b: any) => {
    const [x, y] = [a, b].sort((m, n) => m.slug.localeCompare(n.slug));
    return `${x.slug}-vs-${y.slug}`;
  };

  return listings.map((listing) => {
    const d = listing.data;
    const peers = all
      .filter((t) => t.category === d.category && t.slug !== d.slug)
      .sort((a, b) => (b.rating || 0) - (a.rating || 0));
    const compareLinks = peers.slice(0, 4).map((p) => ({
      name: p.name,
      slug: pairSlug(d, p),
    }));
    return {
      params: { slug: d.slug },
      props: { listing: d, compareLinks },
    };
  });
}

const { listing, compareLinks } = Astro.props;
const categorySlug = listing.category.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '');

// --- GEO answer-first summary (data-driven, no fabrication) ---
const priceText = listing.pricing.startingPrice
  ? `${listing.pricing.model}, starting at ${listing.pricing.startingPrice}`
  : `${listing.pricing.model}`;
const topFeatures = listing.features.slice(0, 3).join(', ');
const ratingText = listing.rating ? `rated ${listing.rating.toFixed(1)}/5` : 'tracked';
const bestForText = (listing.subcategory || listing.category).toLowerCase();
const answer =
  `${listing.name} is a ${listing.pricing.model} ${listing.category} tool — ${listing.tagline} ` +
  `It offers ${listing.features.length} core capabilities${topFeatures ? `, including ${topFeatures}` : ''}. ` +
  `Pricing is ${priceText}. It is ${ratingText} in our ${listing.category.toLowerCase()} directory` +
  `${listing.cons && listing.cons.length ? `, with its main trade-off being ${listing.cons[0].toLowerCase()}` : ''}. ` +
  `${listing.name} is a good fit for anyone comparing ${bestForText} options.`;

// --- Key facts (structured, extractable) ---
const keyFacts: [string, string][] = [
  ['Category', listing.category],
  ['Pricing model', listing.pricing.model],
  ...(listing.pricing.startingPrice ? [['Starting price', listing.pricing.startingPrice] as [string, string]] : []),
  ...(listing.rating ? [['Rating', `${listing.rating.toFixed(1)} / 5.0`] as [string, string]] : []),
  ['Best for', listing.subcategory || listing.category],
  ['Key features', String(listing.features.length)],
  ['Last updated', listing.lastUpdated],
];

// --- Schema: SoftwareApplication + BreadcrumbList in @graph ---
const schema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'SoftwareApplication',
      name: listing.name,
      description: listing.description,
      url: listing.url,
      applicationCategory: listing.category,
      datePublished: listing.lastUpdated,
      dateModified: listing.lastUpdated,
      offers: {
        '@type': 'Offer',
        price: (listing.pricing.startingPrice || '0').replace(/[^0-9.]/g, '') || '0',
        priceCurrency: 'USD',
      },
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: `${siteUrl}/` },
        { '@type': 'ListItem', position: 2, name: listing.category, item: `${siteUrl}/category/${categorySlug}` },
        { '@type': 'ListItem', position: 3, name: listing.name, item: `${siteUrl}/listing/${listing.slug}` },
      ],
    },
  ],
};

// --- FAQs (enriched with GEO-style intent coverage) ---
const faqs = [
  {
    question: `What is ${listing.name}?`,
    answer: listing.description,
  },
  {
    question: `How much does ${listing.name} cost?`,
    answer: listing.pricing.startingPrice
      ? `${listing.name} starts at ${listing.pricing.startingPrice}. The pricing model is ${listing.pricing.model}.`
      : `${listing.name} offers a ${listing.pricing.model} pricing model.`,
  },
  {
    question: `What are the main features of ${listing.name}?`,
    answer: `Key features include: ${listing.features.join(', ')}.`,
  },
  {
    question: `Who is ${listing.name} best for?`,
    answer: `${listing.name} is a good fit for anyone comparing ${bestForText} options${listing.rating ? `, and is rated ${listing.rating.toFixed(1)}/5 in this category` : ''}.`,
  },
  ...(listing.cons && listing.cons.length
    ? [{
        question: `What are the limitations of ${listing.name}?`,
        answer: `Reported trade-offs include: ${listing.cons.join('; ')}.`,
      }]
    : []),
  {
    question: `What are the best ${listing.name} alternatives?`,
    answer: `See our full list of ${listing.name} alternatives, with side-by-side ratings, pricing, and pros & cons, on the ${listing.name} alternatives page.`,
  },
];
---


<BaseLayout
  title={listing.seoTitle || `${listing.name} Review - Features, Pricing & Alternatives`}
  description={listing.seoDescription || listing.tagline}
  schema={schema}
>
  <article class="max-w-3xl">
    <!-- Header -->
    <div class="mb-6">
      <div class="flex items-center gap-2 text-sm text-gray-500 mb-2">
        <a href="/" class="hover:text-blue-600">Home</a>
        <span>/</span>
        <a href={`/category/${categorySlug}`} class="hover:text-blue-600">{listing.category}</a>
        <span>/</span>
        <span>{listing.name}</span>
      </div>
      <h1 class="text-3xl font-bold mb-2">{listing.name}</h1>
      <p class="text-lg text-gray-600">{listing.tagline}</p>
      {listing.rating && (
        <div class="mt-2 text-yellow-600 text-lg">★ {listing.rating.toFixed(1)} / 5.0 <span class="text-xs opacity-60 ml-2">Editors' score</span></div>
      )}
    </div>

    <!-- GEO answer-first summary -->
    <section class="mb-8 bg-blue-50 border border-blue-100 rounded-lg p-5">
      <p class="text-gray-800 leading-relaxed">{answer}</p>
    </section>

    <!-- Key Facts (structured, AI-extractable) -->
    <section class="mb-8">
      <h2 class="text-xl font-semibold mb-3">Key Facts</h2>
      <table class="w-full text-sm border border-gray-200 rounded-lg overflow-hidden">
        <tbody>
          {keyFacts.map(([k, v], i) => (
            <tr class={i % 2 ? 'bg-gray-50' : ''}>
              <th class="text-left p-3 font-medium text-gray-600 w-1/3 align-top">{k}</th>
              <td class="p-3 text-gray-800">{v}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </section>

    <!-- Description -->
    <section class="mb-8">
      <h2 class="text-xl font-semibold mb-3">Overview</h2>
      <p class="text-gray-700 leading-relaxed">{listing.description}</p>
      {!listing.linkDead ? (
      <a href={listing.url} onclick={`trackOutbound('${listing.url}', '${listing.name}', 'visit_button'); return false;`} rel="noopener sponsored" class="inline-block mt-4 px-6 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700">
        Visit {listing.name} →
      </a>
      ) : (
        <p class="mt-4 text-sm text-gray-500 italic">Official site unavailable at our last check (July 2026) — the product may have been discontinued or rebranded.</p>
      )}
    </section>

    <!-- Features -->
    <section class="mb-8">
      <h2 class="text-xl font-semibold mb-3">Key Features</h2>
      <ul class="grid grid-cols-1 md:grid-cols-2 gap-2">
        {listing.features.map((feature: string) => (
          <li class="flex items-center gap-2">
            <span class="text-green-600">✓</span>
            <span>{feature}</span>
          </li>
        ))}
      </ul>
    </section>

    <!-- Pros & Cons -->
    {(listing.pros || listing.cons) && (
      <section class="mb-8 grid grid-cols-1 md:grid-cols-2 gap-6">
        {listing.pros && (
          <div>
            <h3 class="text-lg font-semibold mb-2 text-green-700">Pros</h3>
            <ul class="space-y-1">
              {listing.pros.map((pro: string) => (
                <li class="text-sm">✅ {pro}</li>
              ))}
            </ul>
          </div>
        )}
        {listing.cons && (
          <div>
            <h3 class="text-lg font-semibold mb-2 text-red-700">Cons</h3>
            <ul class="space-y-1">
              {listing.cons.map((con: string) => (
                <li class="text-sm">❌ {con}</li>
              ))}
            </ul>
          </div>
        )}
      </section>
    )}

    <!-- Pricing -->
    <section class="mb-8">
      <h2 class="text-xl font-semibold mb-3">Pricing</h2>
      <div class="bg-gray-50 rounded-lg p-4">
        <p><strong>Model:</strong> {listing.pricing.model}</p>
        {listing.pricing.startingPrice && <p><strong>Starting at:</strong> {listing.pricing.startingPrice}</p>}
      </div>
    </section>

    <!-- Internal links: alternatives / compare / category (GEO authority network) -->
    <section class="mb-8">
      <h2 class="text-xl font-semibold mb-3">Compare {listing.name}</h2>
      <ul class="space-y-2 text-sm">
        <li>
          <a href={`/alternatives/${listing.slug}`} class="text-blue-600 hover:underline">
            → Best {listing.name} alternatives
          </a>
        </li>
        {compareLinks.map((c) => (
          <li>
            <a href={`/compare/${c.slug}`} class="text-blue-600 hover:underline">
              → {listing.name} vs {c.name}
            </a>
          </li>
        ))}
        <li>
          <a href={`/category/${categorySlug}`} class="text-blue-600 hover:underline">
            → All {listing.category} listings
          </a>
        </li>
      </ul>
    </section>

    <!-- Tags -->
    <div class="flex flex-wrap gap-2 mb-8">
      {listing.tags.map((tag: string) => (
        <span class="text-xs bg-gray-100 text-gray-600 px-2 py-1 rounded">{tag}</span>
      ))}
    </div>

    <!-- FAQ -->
    <FAQSection faqs={faqs} />

    <p class="text-xs text-gray-400 mt-8">Last updated: {listing.lastUpdated}</p>
  </article>
</BaseLayout>
