---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FAQSection from '../../components/FAQSection.astro';
import { getCollection } from 'astro:content';

export const prerender = true;

export async function getStaticPaths() {
  const listings = await getCollection('listings');

  // Group by category
  const byCategory: Record<string, typeof listings> = {};
  for (const l of listings) {
    const cat = l.data.category;
    if (!byCategory[cat]) byCategory[cat] = [];
    byCategory[cat].push(l);
  }

  return listings.map((listing) => {
    const alternatives = byCategory[listing.data.category].filter(
      (l) => l.data.slug !== listing.data.slug
    );
    return {
      params: { slug: listing.data.slug },
      props: { tool: listing.data, alternatives: alternatives.map((a) => a.data) },
    };
  });
}

const { tool, alternatives } = Astro.props;
const count = alternatives.length;

// Dynamic title based on tool characteristics (CoS CTR optimization)
const avgPrice = tool.pricing?.startingPrice ? parseInt(tool.pricing.startingPrice.replace(/[^0-9]/g, '')) : 0;
const isExpensive = avgPrice > 100;
const isPaid = tool.pricing?.model === 'paid';

let title;
if (isExpensive && avgPrice > 0) {
  // Expensive tools → emphasize savings
  const savings = Math.round(avgPrice * 0.3); // Estimate 30% savings
  title = `${count} Cheaper ${tool.name} Alternatives (Save $${savings}+/mo) [2026]`;
} else if (tool.rating >= 4.5) {
  // High-rated tools → social proof
  title = `${count} ${tool.name} Alternatives Rated 4.5+ Stars (Free & Paid)`;
} else {
  // Default → value + free anchor
  title = `${count} Better ${tool.name} Alternatives (Free & Paid Options) 2026`;
}

const description = `Compare ${count} top-rated ${tool.name} alternatives with pricing, features & real user reviews. Updated March 2026. Find the best ${tool.category.toLowerCase()} tool →`;

// Schema.org with BreadcrumbList + ItemList (CoS CTR optimization)
const schemas = [
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      {
        '@type': 'ListItem',
        position: 1,
        name: 'Home',
        item: 'https://realestateai.tools/'
      },
      {
        '@type': 'ListItem',
        position: 2,
        name: tool.name,
        item: `https://realestateai.tools/listing/${tool.slug}`
      },
      {
        '@type': 'ListItem',
        position: 3,
        name: 'Alternatives'
      }
    ]
  },
  {
    '@context': 'https://schema.org',
    '@type': 'ItemList',
    name: title,
    numberOfItems: count,
    itemListElement: alternatives.map((alt, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      item: {
        '@type': 'SoftwareApplication',
        name: alt.name,
        description: alt.tagline,
        url: `https://realestateai.tools/listing/${alt.slug}`,
        applicationCategory: alt.category,
      },
    })),
  }
];

// Combine schemas using @graph for JSON-LD
const combinedSchema = {
  '@context': 'https://schema.org',
  '@graph': schemas
};

const faqs = [
  {
    question: `What are the best alternatives to ${tool.name}?`,
    answer: `The top alternatives to ${tool.name} include ${alternatives.map((a) => a.name).join(', ')}. All are ${tool.category} tools with AI-powered features.`,
  },
  {
    question: `Is ${tool.name} the best ${tool.category} tool?`,
    answer: `${tool.name} is a strong option rated ${tool.rating}/5, but the best choice depends on your needs. Compare features and pricing across all ${count + 1} tools in this category.`,
  },
  {
    question: `How do I choose a ${tool.name} alternative?`,
    answer: `Consider your budget, team size, required integrations, and specific ${tool.category.toLowerCase()} needs. Compare the features table above to find the best fit.`,
  },
];
---


<BaseLayout
  title={title}
  description={description}
  schema={combinedSchema}
  canonical={`https://realestateai.tools/alternatives/${tool.slug}`}
>
  <article class="max-w-4xl">
    <!-- Breadcrumb -->
    <div class="flex items-center gap-2 text-sm text-gray-500 mb-4">
      <a href="/" class="hover:text-blue-600">Home</a>
      <span>/</span>
      <a href={`/listing/${tool.slug}`} class="hover:text-blue-600">{tool.name}</a>
      <span>/</span>
      <span>Alternatives</span>
    </div>

    <h1 class="text-3xl font-bold mb-3">{title}</h1>
    <p class="text-gray-600 mb-8 text-lg">
      Not sure if {tool.name} is right for you? Here are the best {tool.category.toLowerCase()} alternatives to consider in 2026.
    </p>

    <!-- About the tool -->
    <section class="bg-gray-50 rounded-lg p-5 mb-8">
      <h2 class="text-lg font-semibold mb-2">About {tool.name}</h2>
      <p class="text-gray-700 text-sm mb-2">{tool.tagline}</p>
      <div class="flex gap-4 text-sm text-gray-500">
        <span>Rating: <strong class="text-yellow-600">★ {tool.rating}</strong></span>
        <span>Pricing: <strong>{tool.pricing.model}{tool.pricing?.startingPrice ? ` from ${tool.pricing?.startingPrice}` : ''}</strong></span>
      </div>
    </section>

    <!-- Comparison Table -->
    <section class="mb-10">
      <h2 class="text-2xl font-semibold mb-4">Feature Comparison</h2>
      <div class="overflow-x-auto">
        <table class="w-full text-sm border border-gray-200 rounded-lg">
          <thead class="bg-gray-50">
            <tr>
              <th class="text-left p-3 border-b">Tool</th>
              <th class="text-left p-3 border-b">Rating</th>
              <th class="text-left p-3 border-b">Pricing</th>
              <th class="text-left p-3 border-b">Key Features</th>
              <th class="text-center p-3 border-b"></th>
            </tr>
          </thead>
          <tbody>
            <tr class="bg-blue-50 border-b">
              <td class="p-3 font-semibold">{tool.name} <span class="text-xs text-blue-600">(current)</span></td>
              <td class="p-3 text-yellow-600">★ {tool.rating}</td>
              <td class="p-3">{tool.pricing.model}{tool.pricing?.startingPrice ? ` from ${tool.pricing?.startingPrice}` : ''}</td>
              <td class="p-3">{tool.features.slice(0, 3).join(', ')}</td>
              <td class="p-3 text-center">
                <a href={`/listing/${tool.slug}`} class="text-blue-600 hover:underline text-xs">View</a>
              </td>
            </tr>
            {alternatives.map((alt) => (
              <tr class="border-b hover:bg-gray-50">
                <td class="p-3 font-medium">{alt.name}</td>
                <td class="p-3 text-yellow-600">★ {alt.rating}</td>
                <td class="p-3">{alt.pricing.model}{alt.pricing.startingPrice ? ` from ${alt.pricing.startingPrice}` : ''}</td>
                <td class="p-3">{alt.features.slice(0, 3).join(', ')}</td>
                <td class="p-3 text-center">
                  <a href={`/listing/${alt.slug}`} class="text-blue-600 hover:underline text-xs">View</a>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <!-- Detailed Alternatives -->
    <section class="mb-10">
      <h2 class="text-2xl font-semibold mb-4">Detailed Look at Each Alternative</h2>
      {alternatives.map((alt, i) => (
        <div class="border border-gray-200 rounded-lg p-5 mb-4">
          <div class="flex items-start justify-between mb-2">
            <h3 class="text-lg font-semibold">{i + 1}. {alt.name}</h3>
            <span class="text-yellow-600 text-sm">★ {alt.rating}/5</span>
          </div>
          <p class="text-gray-700 text-sm mb-3">{alt.description}</p>
          <div class="grid grid-cols-2 gap-4 text-sm">
            <div>
              <strong class="text-green-700">Pros:</strong>
              <ul class="mt-1 space-y-0.5">
                {(alt.pros || []).map((p: string) => <li>✅ {p}</li>)}
              </ul>
            </div>
            <div>
              <strong class="text-red-700">Cons:</strong>
              <ul class="mt-1 space-y-0.5">
                {(alt.cons || []).map((c: string) => <li>❌ {c}</li>)}
              </ul>
            </div>
          </div>
          <div class="mt-3 flex gap-3">
            <a href={`/listing/${alt.slug}`} class="text-sm text-blue-600 hover:underline">Full Review →</a>
            <a href={`/compare/${tool.slug}-vs-${alt.slug}`} class="text-sm text-gray-500 hover:underline">Compare with {tool.name} →</a>
          </div>
        </div>
      ))}
    </section>

    <!-- FAQ -->
    <FAQSection faqs={faqs} />
  </article>
</BaseLayout>
