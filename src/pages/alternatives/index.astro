---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export const prerender = true;

const siteUrl = import.meta.env.SITE || 'https://realestateai.tools';
const listings = (await getCollection('listings')).map((l) => l.data);

// Group by category, then sort categories by size (largest first)
const byCategory: Record<string, typeof listings> = {};
for (const t of listings) {
  (byCategory[t.category] ||= []).push(t);
}
const categories = Object.entries(byCategory)
  .map(([name, tools]) => ({
    name,
    tools: [...tools].sort((a, b) => (b.rating || 0) - (a.rating || 0)),
  }))
  .sort((a, b) => b.tools.length - a.tools.length);

const total = listings.length;
const title = `${total} AI Real Estate Tools & Their Best Alternatives (2026)`;
const description = `Browse alternatives for every AI real estate tool we track. Compare ${total} AI real estate tools across ${categories.length} categories by rating, pricing, and features. Updated 2026.`;

const schema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: `${siteUrl}/` },
        { '@type': 'ListItem', position: 2, name: 'Alternatives' },
      ],
    },
    {
      '@type': 'CollectionPage',
      name: title,
      description,
      url: `${siteUrl}/alternatives`,
    },
    {
      '@type': 'ItemList',
      name: title,
      numberOfItems: total,
      itemListElement: listings.map((t, i) => ({
        '@type': 'ListItem',
        position: i + 1,
        name: `${t.name} alternatives`,
        url: `${siteUrl}/alternatives/${t.slug}`,
      })),
    },
  ],
};
---

<BaseLayout title={title} description={description} schema={schema}>
  <article class="max-w-5xl">
    <div class="flex items-center gap-2 text-sm text-gray-500 mb-4">
      <a href="/" class="hover:text-blue-600">Home</a>
      <span>/</span>
      <span>Alternatives</span>
    </div>

    <h1 class="text-3xl font-bold mb-3">{title}</h1>

    <!-- GEO answer summary -->
    <p class="text-gray-700 mb-8 text-lg leading-relaxed">
      Looking for a different AI real estate tool? This hub lists every one of the {total} AI real estate tools
      we track across {categories.length} categories, each linking to a dedicated page of
      vetted alternatives with side-by-side ratings, pricing, and pros & cons. Options are
      grouped by category and ordered by user rating, so you can jump straight to the closest
      competitors for the one you're evaluating and find a better-fit or lower-cost pick.
    </p>

    {categories.map((cat) => (
      <section class="mb-10">
        <h2 class="text-xl font-semibold mb-4 border-b border-gray-200 pb-2">
          {cat.name} <span class="text-sm font-normal text-gray-400">({cat.tools.length})</span>
        </h2>
        <div class="grid gap-3 sm:grid-cols-2">
          {cat.tools.map((t) => (
            <a
              href={`/alternatives/${t.slug}`}
              class="flex items-center justify-between border border-gray-200 rounded-lg p-3 hover:shadow-md hover:border-blue-300 transition-all"
            >
              <span class="font-medium">{t.name} alternatives</span>
              <span class="text-yellow-600 text-sm whitespace-nowrap">★ {t.rating}</span>
            </a>
          ))}
        </div>
      </section>
    ))}
  </article>
</BaseLayout>
