---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FAQSection from '../../components/FAQSection.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const listings = await getCollection('listings');
  const paths: any[] = [];
  
  // Extract all listings data
  const tools = listings.map(l => l.data);
  
  // Generate one page per ordered pair (A vs B where A < B alphabetically)
  // Cross-category comparisons allowed
  for (let i = 0; i < tools.length; i++) {
    for (let j = i + 1; j < tools.length; j++) {
      const [a, b] = [tools[i], tools[j]].sort((x, y) => x.slug.localeCompare(y.slug));
      paths.push({
        params: { slug: `${a.slug}-vs-${b.slug}` },
        props: { toolA: a, toolB: b },
      });
    }
  }
  
  return paths;
}

const { toolA, toolB } = Astro.props;

// Dynamic title based on price difference (CoS CTR optimization)
const priceA = toolA.pricing?.startingPrice ? parseInt(toolA.pricing.startingPrice.replace(/[^0-9]/g, '')) : 0;
const priceB = toolB.pricing?.startingPrice ? parseInt(toolB.pricing.startingPrice.replace(/[^0-9]/g, '')) : 0;

let title;
if (priceA > 0 && priceB > 0 && Math.abs(priceA - priceB) > 20) {
  // Significant price difference → emphasize cost
  title = `${toolA.name} vs ${toolB.name}: Which Saves More? [Real Cost Comparison 2026]`;
} else if (toolA.rating !== toolB.rating) {
  // Different ratings → emphasize quality
  title = `${toolA.name} vs ${toolB.name}: Which Rates Higher? [Side-by-Side 2026]`;
} else {
  // Default → feature focus
  title = `${toolA.name} vs ${toolB.name}: Honest Comparison [Features & Pricing 2026]`;
}

const description = `${toolA.name} vs ${toolB.name} side-by-side comparison. Pricing, features, pros & cons from real users. Updated March 2026 →`;

const faqs = [
  {
    question: `Is ${toolA.name} better than ${toolB.name}?`,
    answer: `${toolA.name} is rated ${toolA.rating}/5 while ${toolB.name} is rated ${toolB.rating}/5. The best choice depends on your specific needs — ${toolA.name} excels at ${toolA.features?.[0]?.toLowerCase() || toolA.category?.toLowerCase() || "its features"}, while ${toolB.name} is known for ${toolB.features?.[0]?.toLowerCase() || toolB.category?.toLowerCase() || "its features"}.`,
  },
  {
    question: `Which is cheaper, ${toolA.name} or ${toolB.name}?`,
    answer: `${toolA.name} uses a ${toolA.pricing?.model || "flexible"} pricing model${toolA.pricing.startingPrice ? ` starting at ${toolA.pricing.startingPrice}` : ''}. ${toolB.name} uses a ${toolB.pricing?.model || "flexible"} model${toolB.pricing.startingPrice ? ` starting at ${toolB.pricing.startingPrice}` : ''}. Compare both for the best value.`,
  },
  {
    question: `What are the main differences between ${toolA.name} and ${toolB.name}?`,
    answer: `${toolA.name} focuses on ${(toolA.features?.slice(0, 2) || [toolA.category || "features"]).join(" and ").toLowerCase()}, while ${toolB.name} emphasizes ${(toolB.features?.slice(0, 2) || [toolB.category || "features"]).join(" and ").toLowerCase()}. Both are ${toolA.category} tools but serve slightly different use cases.`,
  },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};

function renderStars(rating: number) {
  return '★'.repeat(Math.round(rating)) + '☆'.repeat(5 - Math.round(rating));
}
---

<BaseLayout
  title={title}
  description={description}
  schema={faqSchema}
  canonical={`https://realestateai.tools/compare/${toolA.slug}-vs-${toolB.slug}`}
>
  <article class="max-w-4xl">
    <!-- Breadcrumb -->
    <div class="flex items-center gap-2 text-sm text-gray-500 mb-4">
      <a href="/" class="hover:text-blue-600">Home</a>
      <span>/</span>
      <span>Compare</span>
      <span>/</span>
      <span>{toolA.name} vs {toolB.name}</span>
    </div>

    <h1 class="text-3xl font-bold mb-3">{toolA.name} vs {toolB.name}</h1>
    <p class="text-gray-600 mb-8 text-lg">
      A detailed side-by-side comparison of two popular {toolA.category.toLowerCase()} tools to help you make the right choice.
    </p>

    <!-- Quick Summary Cards -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-8">
      {[toolA, toolB].map((tool) => (
        <div class="border border-gray-200 rounded-lg p-5">
          <h2 class="text-xl font-semibold mb-1">{tool.name}</h2>
          <p class="text-sm text-gray-600 mb-3">{tool.tagline}</p>
          <div class="text-yellow-600 mb-2">{renderStars(tool.rating)} <span class="text-gray-500 text-sm">{tool.rating}/5</span></div>
          <p class="text-sm"><strong>Pricing:</strong> {tool.pricing.model}{tool.pricing.startingPrice ? ` from ${tool.pricing.startingPrice}` : ''}</p>
          <a href={`/listing/${tool.slug}`} class="inline-block mt-3 text-sm text-blue-600 hover:underline">Full Review →</a>
        </div>
      ))}
    </div>

    <!-- Side-by-Side Comparison Table -->
    <section class="mb-10">
      <h2 class="text-2xl font-semibold mb-4">Side-by-Side Comparison</h2>
      <div class="overflow-x-auto">
        <table class="w-full text-sm border border-gray-200 rounded-lg">
          <thead class="bg-gray-50">
            <tr>
              <th class="text-left p-3 border-b w-1/4">Criteria</th>
              <th class="text-left p-3 border-b w-[37.5%]">{toolA.name}</th>
              <th class="text-left p-3 border-b w-[37.5%]">{toolB.name}</th>
            </tr>
          </thead>
          <tbody>
            <tr class="border-b">
              <td class="p-3 font-medium">Rating</td>
              <td class="p-3 text-yellow-600">★ {toolA.rating}/5</td>
              <td class="p-3 text-yellow-600">★ {toolB.rating}/5</td>
            </tr>
            <tr class="border-b bg-gray-50">
              <td class="p-3 font-medium">Pricing Model</td>
              <td class="p-3">{toolA.pricing?.model || "Custom"}{toolA.pricing.startingPrice ? ` from ${toolA.pricing.startingPrice}` : ''}</td>
              <td class="p-3">{toolB.pricing?.model || "Custom"}{toolB.pricing.startingPrice ? ` from ${toolB.pricing.startingPrice}` : ''}</td>
            </tr>
            <tr class="border-b">
              <td class="p-3 font-medium">Key Features</td>
              <td class="p-3">
                <ul class="space-y-1">
                  {(toolA.features || []).map((f: string) => <li class="flex items-start gap-1"><span class="text-green-600 shrink-0">✓</span> {f}</li>)}
                </ul>
              </td>
              <td class="p-3">
                <ul class="space-y-1">
                  {(toolB.features || []).map((f: string) => <li class="flex items-start gap-1"><span class="text-green-600 shrink-0">✓</span> {f}</li>)}
                </ul>
              </td>
            </tr>
            <tr class="border-b bg-gray-50">
              <td class="p-3 font-medium">Pros</td>
              <td class="p-3">
                <ul class="space-y-0.5">
                  {(toolA.pros || []).map((p: string) => <li>✅ {p}</li>)}
                </ul>
              </td>
              <td class="p-3">
                <ul class="space-y-0.5">
                  {(toolB.pros || []).map((p: string) => <li>✅ {p}</li>)}
                </ul>
              </td>
            </tr>
            <tr class="border-b">
              <td class="p-3 font-medium">Cons</td>
              <td class="p-3">
                <ul class="space-y-0.5">
                  {(toolA.cons || []).map((c: string) => <li>❌ {c}</li>)}
                </ul>
              </td>
              <td class="p-3">
                <ul class="space-y-0.5">
                  {(toolB.cons || []).map((c: string) => <li>❌ {c}</li>)}
                </ul>
              </td>
            </tr>
          </tbody>
        </table>
      </div>
    </section>

    <!-- Verdict -->
    <section class="bg-blue-50 rounded-lg p-6 mb-10">
      <h2 class="text-xl font-semibold mb-3">The Verdict</h2>
      <p class="text-gray-700">
        {toolA.rating >= toolB.rating
          ? `${toolA.name} edges ahead with a ${toolA.rating}/5 rating compared to ${toolB.name}'s ${toolB.rating}/5. However, ${toolB.name} may be the better choice if you need ${toolB.features?.[0]?.toLowerCase() || toolB.category?.toLowerCase() || "its features"}.`
          : `${toolB.name} leads with a ${toolB.rating}/5 rating versus ${toolA.name}'s ${toolA.rating}/5. That said, ${toolA.name} could be better if ${toolA.features?.[0]?.toLowerCase() || toolA.category?.toLowerCase() || "its features"} is your priority.`
        }
        Consider your team's specific {toolA.category.toLowerCase()} needs before deciding.
      </p>
      <div class="flex gap-3 mt-4">
        <a href={`/listing/${toolA.slug}`} class="px-4 py-2 bg-blue-600 text-white text-sm rounded-lg hover:bg-blue-700">View {toolA.name}</a>
        <a href={`/listing/${toolB.slug}`} class="px-4 py-2 bg-white text-blue-600 text-sm rounded-lg border border-blue-600 hover:bg-blue-50">View {toolB.name}</a>
      </div>
    </section>

    <!-- Cross-links -->
    <section class="mb-8">
      <h2 class="text-lg font-semibold mb-3">Explore More</h2>
      <div class="flex flex-wrap gap-2">
        <a href={`/alternatives/${toolA.slug}`} class="text-sm px-3 py-1.5 bg-gray-100 rounded-lg hover:bg-gray-200">{toolA.name} Alternatives</a>
        <a href={`/alternatives/${toolB.slug}`} class="text-sm px-3 py-1.5 bg-gray-100 rounded-lg hover:bg-gray-200">{toolB.name} Alternatives</a>
        <a href={`/category/${toolA.category.toLowerCase().replace(/\s+/g, '-')}`} class="text-sm px-3 py-1.5 bg-gray-100 rounded-lg hover:bg-gray-200">All {toolA.category} Tools</a>
      </div>
    </section>

    <!-- FAQ -->
    <FAQSection faqs={faqs} />
  </article>
</BaseLayout>
